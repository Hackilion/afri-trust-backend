# SQLite (default — zero config, works everywhere)
DATABASE_URL=sqlite+aiosqlite:///./afritrust.db
DATABASE_SSL=false

# PostgreSQL (uncomment for production)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_SSL=true

JWT_SECRET_KEY=change-me-to-a-long-random-string
API_KEY_PEPPER=change-me-pepper-value
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# Identity app base URL (no trailing slash) — used in register/resend responses as email_verify_link.
# PUBLIC_APP_URL=http://localhost:5173
# EMAIL_VERIFY_OTP_TTL_MINUTES=30
