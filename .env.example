# SQLite (local dev)
# DATABASE_URL=sqlite+aiosqlite:///./afritrust.db
# DATABASE_SSL=false

# Neon / PostgreSQL — use the pooled connection string from the Neon dashboard.
# Scheme must be postgresql+asyncpg (not postgresql://). Omit channel_binding in the URL for asyncpg.
# Example:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb
DATABASE_SSL=true

JWT_SECRET_KEY=change-me-to-a-long-random-string
API_KEY_PEPPER=change-me-pepper-value
STORAGE_BACKEND=local
UPLOAD_DIR=uploads

# Identity app base URL (no trailing slash) — used in register/resend responses as email_verify_link.
# PUBLIC_APP_URL=http://localhost:5173
# EMAIL_VERIFY_OTP_TTL_MINUTES=30

# Optional: dashboard Assistant uses OpenRouter when set (OpenAI-compatible API; key stays on server).
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_VISION_MODEL=openai/gpt-4o-mini  # optional; defaults to OPENROUTER_MODEL (document pipeline + liveness)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-app.example  # optional; defaults to PUBLIC_APP_URL
