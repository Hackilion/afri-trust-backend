{
  "info": {
    "name": "AfriTrust API",
    "description": "Complete AfriTrust identity verification API collection.\n\nEach folder contains both positive (happy path) and negative (validation) tests.\nRun folders in order: Authentication → API Keys → Tier Profiles → Workflows → Applicants → Verifications → KYC Data & Reports → Consent & Identity → Webhooks → Audit Logs.\n\nVariables auto-chain between requests via test scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:8000/v1"},
    {"key": "jwt_token", "value": ""},
    {"key": "refresh_token", "value": ""},
    {"key": "api_key", "value": ""},
    {"key": "org_id", "value": ""},
    {"key": "basic_tier_id", "value": ""},
    {"key": "advanced_tier_id", "value": ""},
    {"key": "workflow_id", "value": ""},
    {"key": "draft_wf_id", "value": ""},
    {"key": "step1_id", "value": ""},
    {"key": "applicant_id", "value": ""},
    {"key": "session_id", "value": ""},
    {"key": "verification_token", "value": ""},
    {"key": "webhook_id", "value": ""},
    {"key": "consent_id", "value": ""},
    {"key": "email_verify_token", "value": ""}
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Organization",
          "event": [{"listen": "test", "script": {"exec": ["var d = pm.response.json();", "pm.collectionVariables.set('org_id', d.org_id);", "pm.collectionVariables.set('email_verify_token', d.email_verify_token);", "pm.test('201 Created', () => pm.response.to.have.status(201));", "pm.test('Returns verify token', () => pm.expect(d.email_verify_token).to.be.a('string'));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@afritrust-demo.com\",\n  \"password\": \"SecurePass123!\",\n  \"org_name\": \"AfriTrust Demo Org\",\n  \"legal_name\": \"AfriTrust Demo Ltd\",\n  \"country\": \"ET\",\n  \"industry\": \"fintech\"\n}"}, "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}}
        },
        {
          "name": "NEGATIVE: Register with weak password",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422 Validation Error', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"weak\",\n  \"org_name\": \"Test\"\n}"}, "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}}
        },
        {
          "name": "NEGATIVE: Register duplicate email",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('409 Conflict', () => pm.response.to.have.status(409));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@afritrust-demo.com\",\n  \"password\": \"Secure123\",\n  \"org_name\": \"Duplicate Org\"\n}"}, "url": {"raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"]}}
        },
        {
          "name": "NEGATIVE: Login before email verification",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('401 Email not verified', () => pm.response.to.have.status(401));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@afritrust-demo.com\",\n  \"password\": \"SecurePass123!\"\n}"}, "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}}
        },
        {
          "name": "NEGATIVE: Verify with invalid token",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('400 Bad Request', () => pm.response.to.have.status(400));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"token\": \"invalid-fake-token\"}"}, "url": {"raw": "{{base_url}}/auth/verify-email", "host": ["{{base_url}}"], "path": ["auth", "verify-email"]}}
        },
        {
          "name": "Verify Email",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('200 OK', () => pm.response.to.have.status(200));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"token\": \"{{email_verify_token}}\"}"}, "url": {"raw": "{{base_url}}/auth/verify-email", "host": ["{{base_url}}"], "path": ["auth", "verify-email"]}}
        },
        {
          "name": "NEGATIVE: Login with wrong password",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('401', () => pm.response.to.have.status(401));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"email\": \"admin@afritrust-demo.com\", \"password\": \"WrongPass1\"}"}, "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}}
        },
        {
          "name": "Login",
          "event": [{"listen": "test", "script": {"exec": ["var d = pm.response.json();", "pm.collectionVariables.set('jwt_token', d.access_token);", "pm.collectionVariables.set('refresh_token', d.refresh_token);", "pm.test('200 OK', () => pm.response.to.have.status(200));", "pm.test('Has tokens', () => pm.expect(d.access_token).to.be.a('string'));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@afritrust-demo.com\",\n  \"password\": \"SecurePass123!\"\n}"}, "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}}
        },
        {
          "name": "Get Current User (me)",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('200', () => pm.response.to.have.status(200));", "pm.test('Has org', () => pm.expect(pm.response.json().org_name).to.be.a('string'));"]}}],
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"]}}
        },
        {
          "name": "Refresh Token",
          "event": [{"listen": "test", "script": {"exec": ["pm.collectionVariables.set('jwt_token', pm.response.json().access_token);", "pm.test('200', () => pm.response.to.have.status(200));"]}}],
          "request": {"method": "POST", "header": [{"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"refresh_token\": \"{{refresh_token}}\"}"}, "url": {"raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"]}}
        },
        {
          "name": "NEGATIVE: Access without auth",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('401', () => pm.response.to.have.status(401));"]}}],
          "request": {"method": "GET", "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        }
      ]
    },
    {
      "name": "2. API Keys",
      "item": [
        {
          "name": "Create API Key",
          "event": [{"listen": "test", "script": {"exec": ["var d = pm.response.json();", "pm.collectionVariables.set('api_key', d.api_key);", "pm.test('201', () => pm.response.to.have.status(201));", "pm.test('Secret returned once', () => pm.expect(d.api_key.length).to.be.above(20));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"mobile-sdk-key\",\n  \"scopes\": [\"read\", \"write\"]\n}"}, "url": {"raw": "{{base_url}}/api-keys", "host": ["{{base_url}}"], "path": ["api-keys"]}}
        },
        {
          "name": "List API Keys",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('200 + array', () => { pm.response.to.have.status(200); pm.expect(pm.response.json()).to.be.an('array'); });"]}}],
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/api-keys", "host": ["{{base_url}}"], "path": ["api-keys"]}}
        }
      ]
    },
    {
      "name": "3. Tier Profiles",
      "item": [
        {
          "name": "Get Check Catalogue",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Has check types', () => pm.expect(pm.response.json().check_types.length).to.be.above(0));"]}}],
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/tier-profiles/check-catalogue", "host": ["{{base_url}}"], "path": ["tier-profiles", "check-catalogue"]}}
        },
        {
          "name": "Create Basic KYC Tier",
          "event": [{"listen": "test", "script": {"exec": ["pm.collectionVariables.set('basic_tier_id', pm.response.json().id);", "pm.test('201', () => pm.response.to.have.status(201));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Basic KYC\",\n  \"description\": \"Email, phone, and selfie verification\",\n  \"required_checks\": [\"email\", \"phone\", \"selfie\"],\n  \"attribute_schema\": [\n    {\"key\": \"full_name\", \"label\": \"Full Name\", \"data_type\": \"string\", \"required\": true, \"validation\": {\"min_length\": 2, \"max_length\": 200}},\n    {\"key\": \"email_address\", \"label\": \"Email\", \"data_type\": \"string\", \"required\": true},\n    {\"key\": \"phone_number\", \"label\": \"Phone\", \"data_type\": \"string\", \"required\": true}\n  ],\n  \"accepted_document_types\": [],\n  \"settings\": {}\n}"}, "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "Create Document + Biometric Tier",
          "event": [{"listen": "test", "script": {"exec": ["pm.collectionVariables.set('advanced_tier_id', pm.response.json().id);", "pm.test('201', () => pm.response.to.have.status(201));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Document + Biometric\",\n  \"description\": \"Government ID with OCR + face matching\",\n  \"required_checks\": [\"government_id\", \"face_match\"],\n  \"attribute_schema\": [\n    {\"key\": \"id_number\", \"label\": \"ID Number\", \"data_type\": \"string\", \"required\": true},\n    {\"key\": \"date_of_birth\", \"label\": \"Date of Birth\", \"data_type\": \"date\", \"required\": true},\n    {\"key\": \"nationality\", \"label\": \"Nationality\", \"data_type\": \"string\", \"required\": true},\n    {\"key\": \"gender\", \"label\": \"Gender\", \"data_type\": \"enum\", \"required\": false, \"options\": [\"male\", \"female\", \"other\"]}\n  ],\n  \"accepted_document_types\": [\"passport\", \"national_id\", \"drivers_license\"],\n  \"settings\": {\"face_match_threshold\": 0.85}\n}"}, "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "NEGATIVE: Invalid check type",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"Bad\",\"required_checks\":[\"nonexistent\"],\"attribute_schema\":[],\"settings\":{}}"}, "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "NEGATIVE: Duplicate attribute keys",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"Bad\",\"required_checks\":[\"email\"],\"attribute_schema\":[{\"key\":\"name\",\"label\":\"N\",\"data_type\":\"string\"},{\"key\":\"name\",\"label\":\"N2\",\"data_type\":\"string\"}],\"settings\":{}}"}, "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "NEGATIVE: Enum without options",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\":\"Bad\",\"required_checks\":[\"email\"],\"attribute_schema\":[{\"key\":\"g\",\"label\":\"G\",\"data_type\":\"enum\"}],\"settings\":{}}"}, "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "List Tier Profiles",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/tier-profiles", "host": ["{{base_url}}"], "path": ["tier-profiles"]}}
        },
        {
          "name": "Get Tier Profile by ID",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/tier-profiles/{{basic_tier_id}}", "host": ["{{base_url}}"], "path": ["tier-profiles", "{{basic_tier_id}}"]}}
        }
      ]
    },
    {
      "name": "4. Workflows",
      "item": [
        {
          "name": "Create Workflow (draft)",
          "event": [{"listen": "test", "script": {"exec": ["var d = pm.response.json();", "pm.collectionVariables.set('workflow_id', d.id);", "pm.test('201 draft', () => { pm.response.to.have.status(201); pm.expect(d.status).to.eql('draft'); });"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"name\": \"Fintech Full KYC\",\n  \"description\": \"Two-step verification: basic info + document with biometrics\"\n}"}, "url": {"raw": "{{base_url}}/workflows", "host": ["{{base_url}}"], "path": ["workflows"]}}
        },
        {
          "name": "Add Step 1 (Basic KYC)",
          "event": [{"listen": "test", "script": {"exec": ["pm.collectionVariables.set('step1_id', pm.response.json().id);", "pm.test('201', () => pm.response.to.have.status(201));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"tier_profile_id\": \"{{basic_tier_id}}\", \"step_order\": 1}"}, "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/steps", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "steps"]}}
        },
        {
          "name": "Add Step 2 (Doc + Bio)",
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"tier_profile_id\": \"{{advanced_tier_id}}\", \"step_order\": 2}"}, "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/steps", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "steps"]}}
        },
        {
          "name": "NEGATIVE: Step order 0",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"tier_profile_id\": \"{{basic_tier_id}}\", \"step_order\": 0}"}, "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/steps", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "steps"]}}
        },
        {
          "name": "List Steps",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/steps", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "steps"]}}
        },
        {
          "name": "Publish Workflow",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('Published', () => pm.expect(pm.response.json().status).to.eql('published'));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/publish", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "publish"]}}
        },
        {
          "name": "NEGATIVE: Edit published workflow",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"name\": \"Changed\"}"}, "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}"]}}
        },
        {
          "name": "NEGATIVE: Add step to published",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('422', () => pm.response.to.have.status(422));"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"tier_profile_id\": \"{{basic_tier_id}}\", \"step_order\": 3}"}, "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/steps", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "steps"]}}
        },
        {
          "name": "Get Workflow Detail",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}"]}}
        },
        {
          "name": "List Workflows",
          "request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/workflows?status=published", "host": ["{{base_url}}"], "path": ["workflows"], "query": [{"key": "status", "value": "published"}]}}
        },
        {
          "name": "Clone Workflow",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('201 draft copy', () => { pm.response.to.have.status(201); pm.expect(pm.response.json().status).to.eql('draft'); });"]}}],
          "request": {"method": "POST", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}], "url": {"raw": "{{base_url}}/workflows/{{workflow_id}}/clone", "host": ["{{base_url}}"], "path": ["workflows", "{{workflow_id}}", "clone"]}}
        }
      ]
    },
    {
      "name": "5. Applicants",
      "item": [
        {
          "name": "Create Applicant (via API Key)",
          "event": [{"listen": "test", "script": {"exec": ["pm.collectionVariables.set('applicant_id', pm.response.json().id);", "pm.test('201', () => pm.response.to.have.status(201));"]}}],
          "request": {"method": "POST", "header": [{"key": "X-API-Key", "value": "{{api_key}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"external_id\": \"user-42\",\n  \"email\": \"abebe.kebede@example.com\",\n  \"phone\": \"+251911223344\",\n  \"full_name\": \"Abebe Kebede\",\n  \"metadata\": {\"source\": \"mobile_app\", \"country\": \"ET\"}\n}"}, "url": {"raw": "{{base_url}}/applicants", "host": ["{{base_url}}"], "path": ["applicants"]}}
        },
        {
          "name": "NEGATIVE: Duplicate external_id",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('409', () => pm.response.to.have.status(409));"]}}],
          "request": {"method": "POST", "header": [{"key": "X-API-Key", "value": "{{api_key}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"external_id\": \"user-42\", \"full_name\": \"Duplicate\"}"}, "url": {"raw": "{{base_url}}/applicants", "host": ["{{base_url}}"], "path": ["applicants"]}}
        },
        {
          "name": "NEGATIVE: Get non-existent applicant",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('404', () => pm.response.to.have.status(404));"]}}],
          "request": {"method": "GET", "header": [{"key": "X-API-Key", "value": "{{api_key}}"}], "url": {"raw": "{{base_url}}/applicants/00000000-0000-0000-0000-000000000000", "host": ["{{base_url}}"], "path": ["applicants", "00000000-0000-0000-0000-000000000000"]}}
        },
        {
          "name": "Get Applicant",
          "request": {"method": "GET", "header": [{"key": "X-API-Key", "value": "{{api_key}}"}], "url": {"raw": "{{base_url}}/applicants/{{applicant_id}}", "host": ["{{base_url}}"], "path": ["applicants", "{{applicant_id}}"]}}
        },
        {
          "name": "Update Applicant",
          "request": {"method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{jwt_token}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\"phone\": \"+251922334455\", \"metadata\": {\"updated\": true}}"}, "url": {"raw": "{{base_url}}/applicants/{{applicant_id}}", "host": ["{{base_url}}"], "path": ["applicants", "{{applicant_id}}"]}}
        }
      ]
    },
    {
      "name": "6. Verification Flow",
      "item": [
        {
          "name": "Start Verification Session",
          "event": [{"listen": "test", "script": {"exec": ["var d = pm.response.json();", "pm.collectionVariables.set('session_id', d.id);", "pm.test('201 created', () => { pm.response.to.have.status(201); pm.expect(d.status).to.eql('created'); });"]}}],
          "request": {"method": "POST", "header": [{"key": "X-API-Key", "value": "{{api_key}}"}, {"key": "Content-Type", "value": "application/json"}], "body": {"mode": "raw", "raw": "{\n  \"applicant_id\": \"{{applicant_id}}\",\n  \"workflow_id\": \"{{workflow_id}}\"\n}"}, "url": {"raw": "{{base_url}}/verifications", "host": ["{{base_url}}"], "path": ["verifications"]}}
        },
        {
          "name": "NEGATIVE: Duplicate active session",
          "event": [{"listen": "test", "script": {"exec": ["pm.test('400', () => pm.response.to.have.status(400));"]}}],
